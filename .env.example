# Aura Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Redis
AURA_REDIS_URL=redis://localhost:6379/0

# Milvus
AURA_VECTOR_DB_HOST=localhost
AURA_VECTOR_DB_PORT=19530

# Ray
AURA_RAY_ENABLED=false
AURA_RAY_ADDRESS=auto

# Inference
AURA_INFERENCE_MAX_LATENCY_MS=200
AURA_LLM_MOCK_MODE=true

# Telemetry
AURA_TELEMETRY_ENABLED=true
